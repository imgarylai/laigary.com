{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "laigary-og-spike",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "rules": [{ "type": "Data", "globs": ["**/*.ttf"], "fallthrough": true }],
}
